{
  "$schema": "https://raw.githubusercontent.com/ulises-jeremias/agentic-workstation/main/lib/schemas/skill.schema.json",
  "name": "dots-workstation-loop-runner",
  "version": "1.0.0",
  "description": "Execute and manage loop engineering primitives from an AI coding session. Wraps ai-workspace bin/loop with safety-first defaults (start at L1, budget-aware, allowlist-enforced).",
  "source": "bundled",
  "author": "agentic-workstation",
  "tags": [
    "loop-engineering",
    "automation",
    "orchestration",
    "scheduling"
  ],
  "requires": [
    "python3"
  ],
  "trigger_points": [
    "loop_init_requested",
    "loop_run_requested",
    "loop_status_check",
    "loop_audit_requested"
  ],
  "dependencies": [
    "dots-workstation-assistant"
  ],
  "compatibility": {
    "universal": { "supported": true },
    "claude-code": { "supported": true },
    "opencode": { "supported": true },
    "cursor": { "supported": true },
    "windsurf": { "supported": true },
    "copilot-cli": { "supported": false },
    "pi": { "supported": true }
  }
}
