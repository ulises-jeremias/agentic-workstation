#!/usr/bin/env bash
set -eo pipefail

## dots-uninstall
##
## Removes agentic-workstation components from your machine.
##
## Usage:
##     dots-uninstall [option]
##
## Options:
##     -h, --help              Show this help message.
##         --dry-run           Preview what would be removed without making changes.
##         --keep-config       Preserve ~/.config/agentic-workstation/ directory.
##         --remove-skills     Remove ~/.local/share/agentic-workstation/ skills directory.
##         --remove-checksums  Remove chezmoi checksums (forces re-apply on next init).
##         --all               Remove everything (config, skills, checksums).
##

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_DOTS_WORKSTATION_LIB_DIR="$(cd -- "${SCRIPT_DIR}/../lib/agentic-workstation" 2>/dev/null && pwd || true)"
DOTS_WORKSTATION_LIB_DIR="${DOTS_WORKSTATION_LIB_DIR:-${DEFAULT_DOTS_WORKSTATION_LIB_DIR:-$HOME/.local/lib/agentic-workstation}}"
EASY_OPTIONS_LIB="${DOTS_WORKSTATION_LIB_DIR}/easy-options/easyoptions.sh"

options=(h=help dry-run keep-config remove-skills remove-checksums all)

if [[ -f ${EASY_OPTIONS_LIB} ]]; then
  source "${EASY_OPTIONS_LIB}"
fi

if [[ -t 1 && -z ${NO_COLOR:-} ]]; then
  c_reset=$'\033[0m'
  c_blue=$'\033[1;34m'
  c_red=$'\033[1;31m'
  c_green=$'\033[1;32m'
  c_yellow=$'\033[1;33m'
else
  c_reset=''
  c_blue=''
  c_red=''
  c_green=''
  c_yellow=''
fi

info()  { printf '%b[dots-uninstall]%b %s\n' "$c_blue" "$c_reset" "$*"; }
fail()  { printf '%b[dots-uninstall]%b %s\n' "$c_red" "$c_reset" "$*"; }
ok()    { printf '%b[dots-uninstall]%b %s\n' "$c_green" "$c_reset" "$*"; }
warn()  { printf '%b[dots-uninstall]%b %s\n' "$c_yellow" "$c_reset" "$*"; }

DRY_RUN="${dry_run:-false}"
KEEP_CONFIG="${keep_config:-false}"
REMOVE_SKILLS="${remove_skills:-false}"
REMOVE_CHECKSUMS="${remove_checksums:-false}"
ALL="${all:-false}"

if [[ "${ALL}" == "true" ]]; then
  KEEP_CONFIG="false"
  REMOVE_SKILLS="true"
  REMOVE_CHECKSUMS="true"
fi

HOME_DIR="${HOME:?HOME not set}"
CONFIG_DIR="${HOME}/.config/agentic-workstation"
SHARE_DIR="${HOME}/.local/share/agentic-workstation"
BIN_DIR="${HOME}/.local/bin"
AGENTS_DIR="${HOME}/.agents"
CLAUDE_SKILLS="${HOME}/.claude/skills"
CURSOR_SKILLS="${HOME}/.cursor/skills"
PI_SKILLS="${HOME}/.pi/agent/skills"
WINDSURF_SKILLS="${HOME}/.windsurf/skills"
CHEZMOI_CHECKSUMS="${HOME}/.local/share/chezmoi/checksums"

do_remove() {
  local target="$1"
  if [[ ! -e "${target}" ]]; then
    ok "not found, skipping: ${target}"
    return 0
  fi

  if [[ "${DRY_RUN}" == "true" ]]; then
    info "[DRY-RUN] would remove: ${target}"
    return 0
  fi

  rm -rf "${target}"
  ok "removed: ${target}"
}

do_remove_file() {
  local target="$1"
  if [[ ! -f "${target}" ]]; then
    ok "not found, skipping: ${target}"
    return 0
  fi

  if [[ "${DRY_RUN}" == "true" ]]; then
    info "[DRY-RUN] would remove: ${target}"
    return 0
  fi

  rm -f "${target}"
  ok "removed: ${target}"
}

do_remove_skills_symlinks() {
  local dir="$1"
  local label="$2"
  if [[ ! -d "${dir}" ]]; then
    ok "not found, skipping ${label}: ${dir}"
    return 0
  fi

  local count=0
  while IFS= read -r -d '' link; do
    local target
    target="$(readlink -f "${link}" 2>/dev/null || true)"
    if [[ "${target}" == *"agentic-workstation"* || "${target}" == *"dots-ai"* ]]; then
      do_remove_file "${link}"
      ((count++)) || true
    fi
  done < <(find "${dir}" -type l -print0 2>/dev/null || true)

  if [[ ${count} -gt 0 ]]; then
    ok "removed ${count} ${label} skill symlinks"
  else
    ok "no ${label} skill symlinks found"
  fi
}

echo ""
info "agentic-workstation uninstall"
info "=============================="
echo ""

if [[ "${DRY_RUN}" == "true" ]]; then
  warn "DRY-RUN mode — no changes will be made"
  echo ""
fi

# Ask for confirmation in non-dry-run mode
if [[ "${DRY_RUN}" != "true" ]]; then
  echo "This will remove agentic-workstation components from your machine."
  echo ""
  if [[ "${ALL}" == "true" ]]; then
    echo "Mode: FULL — config, skills, checksums"
  else
    echo "Mode: DEFAULT — symbolic links and cache only"
    [[ "${KEEP_CONFIG}" == "false" ]] && echo "  - Config: will be removed"
    [[ "${KEEP_CONFIG}" == "true" ]] && echo "  - Config: will be KEPT"
    [[ "${REMOVE_SKILLS}" == "true" ]] && echo "  - Skills: will be removed"
    [[ "${REMOVE_CHECKSUMS}" == "true" ]] && echo "  - Chezmoi checksums: will be removed"
  fi
  echo ""
  echo "Your dotfiles managed by chezmoi are NOT affected by this command."
  echo "To remove dotfiles, use: chezmoi purge"
  echo ""

  read -r -p "Continue? [y/N] " response
  if [[ ! "${response}" =~ ^[Yy]$ ]]; then
    info "uninstall cancelled"
    exit 0
  fi
  echo ""
fi

# 1. Remove AI skill symlinks (always safe — just links)
info "removing AI skill symlinks..."
do_remove_skills_symlinks "${CLAUDE_SKILLS}" "Claude Code"
do_remove_skills_symlinks "${CURSOR_SKILLS}" "Cursor"
do_remove_skills_symlinks "${PI_SKILLS}" "Pi"
do_remove_skills_symlinks "${WINDSURF_SKILLS}" "Windsurf"

# 2. Remove agents symlink directory
info "removing agent symlinks..."
do_remove "${AGENTS_DIR}"

# 3. Remove config directory (unless --keep-config)
if [[ "${KEEP_CONFIG}" != "true" && "${DRY_RUN}" != "true" ]] || [[ "${DRY_RUN}" == "true" ]]; then
  info "removing config directory..."
  do_remove "${CONFIG_DIR}"
else
  ok "keeping config directory: ${CONFIG_DIR}"
fi

# 4. Remove skills directory (only with --remove-skills or --all)
if [[ "${REMOVE_SKILLS}" == "true" ]]; then
  info "removing skills directory..."
  do_remove "${SHARE_DIR}"
else
  ok "keeping skills directory (use --remove-skills or --all to remove): ${SHARE_DIR}"
fi

# 5. Remove chezmoi checksums (only with --remove-checksums or --all)
if [[ "${REMOVE_CHECKSUMS}" == "true" ]]; then
  info "removing chezmoi checksums..."
  do_remove_file "${CHEZMOI_CHECKSUMS}"
else
  ok "keeping chezmoi checksums (use --remove-checksums or --all to remove)"
fi

echo ""
if [[ "${DRY_RUN}" == "true" ]]; then
  info "DRY-RUN complete. Run without --dry-run to apply."
else
  ok "uninstall complete"
  echo ""
  info "Your dotfiles are still managed by chezmoi."
  info "To remove them, run: chezmoi purge"
  if [[ "${REMOVE_SKILLS}" != "true" ]]; then
    info "To remove skills, run: dots-uninstall --remove-skills"
  fi
  info "To reinstall skills, run: curl -fsSL https://github.com/ulises-jeremias/agentic-workstation/releases/latest/download/install-skills.sh | bash"
fi
echo ""
