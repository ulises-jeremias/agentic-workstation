#!/usr/bin/env bash
# dots-mcp — MCP provider setup wizard and health checker for agentic-workstation.
#
# Discovers available MCP templates under ~/.local/share/agentic-workstation/mcp/ and
# guides users through environment variable configuration.
#
# Usage:
#   dots-mcp list                    List available MCP providers
#   dots-mcp setup <provider>        Interactive setup wizard
#   dots-mcp doctor [provider]       Validate env, check connectivity
#   dots-mcp show <provider>         Print config template
#
# Examples:
#   dots-mcp list
#   dots-mcp setup github
#   dots-mcp doctor github
#   dots-mcp doctor

set -euo pipefail

DOTS_WORKSTATION_SHARE="${HOME}/.local/share/agentic-workstation"
MCP_DIR="${DOTS_WORKSTATION_SHARE}/mcp"

if [[ -t 1 && -z ${NO_COLOR:-} ]]; then
  c_reset=$'\033[0m'
  c_blue=$'\033[1;34m'
  c_green=$'\033[1;32m'
  c_red=$'\033[1;31m'
  c_yellow=$'\033[1;33m'
  c_dim=$'\033[2m'
else
  c_reset='' c_blue='' c_green='' c_red='' c_yellow='' c_dim=''
fi

info() { printf '%b[dots-mcp]%b %s\n' "${c_blue}" "${c_reset}" "$*"; }
ok() { printf '  %b✓%b %s\n' "${c_green}" "${c_reset}" "$*"; }
fail() { printf '  %b✗%b %s\n' "${c_red}" "${c_reset}" "$*"; }
warn() { printf '  %b!%b %s\n' "${c_yellow}" "${c_reset}" "$*"; }
dim() { printf '%b%s%b\n' "${c_dim}" "$*" "${c_reset}"; }
die() {
  printf '%b[dots-mcp] error:%b %s\n' "${c_red}" "${c_reset}" "$*" >&2
  exit 1
}

# ── Discover providers ────────────────────────────────────────────────────────

list_providers() {
  if [[ ! -d ${MCP_DIR} ]]; then
    echo "No MCP templates found at ${MCP_DIR}" >&2
    echo "Install agentic-workstation and run: chezmoi apply"
    return 1
  fi
  for d in "${MCP_DIR}"/*/; do
    [[ -d ${d} ]] || continue
    provider=$(basename "${d}")
    config="${d}/config.template.json"
    readme="${d}/README.md"
    desc=""
    if [[ -f ${readme} ]]; then
      desc=$(head -3 "${readme}" | grep -v "^#" | grep -v "^$" | head -1 || true)
    fi
    printf '  %-15s %s\n' "${provider}" "${desc}"
  done
}

# Extract required env vars from config template
required_vars() {
  local provider="$1"
  local config="${MCP_DIR}/${provider}/config.template.json"
  [[ -f ${config} ]] || return 0
  # Extract ${VAR_NAME} patterns from the template
  grep -oE '\$\{[A-Z_]+\}' "${config}" | sort -u | sed 's/\${\(.*\)}/\1/'
}

# ── setup wizard ──────────────────────────────────────────────────────────────

cmd_setup() {
  local provider="${1:-}"
  [[ -z ${provider} ]] && die "Usage: dots-mcp setup <provider>\nRun 'dots-mcp list' to see available providers."

  local provider_dir="${MCP_DIR}/${provider}"
  [[ -d ${provider_dir} ]] || die "Provider '${provider}' not found. Run 'dots-mcp list'."

  info "Setting up MCP provider: ${provider}"
  echo ""

  # Show README if available
  local readme="${provider_dir}/README.md"
  if [[ -f ${readme} ]]; then
    dim "--- ${provider} README ---"
    cat "${readme}"
    dim "------------------------"
    echo ""
  fi

  # Check and prompt for required env vars
  local vars
  mapfile -t vars < <(required_vars "${provider}")

  if [[ ${#vars[@]} -eq 0 ]]; then
    ok "No environment variables required for ${provider}."
  else
    info "Required environment variables:"
    for var in "${vars[@]}"; do
      if [[ -n ${!var:-} ]]; then
        ok "${var} is set"
      else
        warn "${var} is NOT set"
        echo ""
        printf "  To set it, add to your AI tool's env or to %s:\n" "${HOME}/.config/agentic-workstation/env.d/${provider}.env"
        printf "    export %s=\"your-value-here\"\n" "${var}"
        echo ""
      fi
    done
  fi

  echo ""

  # Show config template
  local config="${provider_dir}/config.template.json"
  if [[ -f ${config} ]]; then
    info "Config template (${provider}/config.template.json):"
    cat "${config}"
    echo ""
  fi

  # Show wrapper.sh if present
  local wrapper="${provider_dir}/wrapper.sh"
  if [[ -f ${wrapper} ]]; then
    info "Wrapper script available at: ${wrapper}"
    echo ""
  fi

  info "Run 'dots-mcp doctor ${provider}' to verify the setup."
}

# ── doctor ────────────────────────────────────────────────────────────────────

cmd_doctor() {
  local provider="${1:-}"

  if [[ -n ${provider} ]]; then
    providers=("${provider}")
  else
    mapfile -t providers < <(ls "${MCP_DIR}" 2>/dev/null)
  fi

  echo ""
  info "MCP Health Check"
  echo ""

  for p in "${providers[@]}"; do
    local provider_dir="${MCP_DIR}/${p}"
    [[ -d ${provider_dir} ]] || continue

    printf '  %s\n' "${p}"

    # Check env vars
    local all_set=true
    while IFS= read -r var; do
      [[ -z ${var} ]] && continue
      if [[ -n ${!var:-} ]]; then
        ok "  ${var} is set"
      else
        fail "  ${var} is NOT set"
        all_set=false
      fi
    done < <(required_vars "${p}")

    # Check config template is parseable JSON
    local config="${provider_dir}/config.template.json"
    if [[ -f ${config} ]]; then
      if python3 -c "import json; json.load(open('${config}'))" 2>/dev/null; then
        ok "  config.template.json is valid JSON"
      else
        fail "  config.template.json is invalid JSON"
      fi
    fi

    if [[ ${all_set} == "true" ]]; then
      ok "  ${p}: all required env vars set"
    else
      warn "  ${p}: some env vars missing — run 'dots-mcp setup ${p}'"
    fi
    echo ""
  done
}

# ── show ──────────────────────────────────────────────────────────────────────

cmd_show() {
  local provider="${1:-}"
  [[ -z ${provider} ]] && die "Usage: dots-mcp show <provider>"
  local config="${MCP_DIR}/${provider}/config.template.json"
  [[ -f ${config} ]] || die "Config not found for '${provider}'. Run 'dots-mcp list'."
  cat "${config}"
}

# ── Main ──────────────────────────────────────────────────────────────────────

command="${1:-}"
shift || true

case "${command}" in
  list) list_providers ;;
  setup) cmd_setup "${1:-}" ;;
  doctor) cmd_doctor "${1:-}" ;;
  show) cmd_show "${1:-}" ;;
  "" | --help | -h)
    echo "dots-mcp — MCP provider setup wizard and health checker"
    echo ""
    echo "Usage:"
    echo "  dots-mcp list                    List available MCP providers"
    echo "  dots-mcp setup <provider>        Interactive setup wizard"
    echo "  dots-mcp doctor [provider]       Validate env and config"
    echo "  dots-mcp show <provider>         Print config template"
    ;;
  *)
    die "Unknown command '${command}'. Run 'dots-mcp --help'."
    ;;
esac
